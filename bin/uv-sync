# Manual uv sync wrapper (optional - auto-managed by investorclaw)
#
# InvestorClaw automatically manages dependencies via `uv sync`.
# This script is provided for manual syncing if needed.
#
# Usage:
#   ./bin/uv-sync              # Sync in current project
#   ./bin/uv-sync --upgrade    # Upgrade all packages
#   ./bin/uv-sync --clean      # Clean venv and resync

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log_step() {
    echo -e "${BLUE}→${NC} $1"
}

log_success() {
    echo -e "${GREEN}✓${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

log_error() {
    echo -e "${RED}✗${NC} $1"
}

# Check for uv
if ! command -v uv &> /dev/null; then
    log_error "uv not found. Installing..."
    if command -v curl &> /dev/null; then
        curl -LsSf https://astral.sh/uv/install.sh | sh
        export PATH="$HOME/.local/bin:$PATH"
        log_success "uv installed"
    else
        log_error "curl required to install uv"
        exit 1
    fi
fi

cd "$PROJECT_ROOT"

case "${1:-sync}" in
    sync)
        log_step "Syncing dependencies..."
        uv sync
        log_success "Dependencies synced"
        ;;
    upgrade)
        log_step "Upgrading dependencies..."
        uv sync --upgrade
        log_success "Dependencies upgraded"
        ;;
    clean)
        log_step "Cleaning virtual environment..."
        rm -rf .venv
        log_step "Recreating virtual environment..."
        uv sync
        log_success "Virtual environment cleaned and synced"
        ;;
    --help|-h|help)
        echo "InvestorClaw uv Sync Wrapper"
        echo ""
        echo "Usage: $0 [COMMAND]"
        echo ""
        echo "Commands:"
        echo "  sync       - Sync dependencies (default)"
        echo "  upgrade    - Upgrade all packages to latest versions"
        echo "  clean      - Remove and recreate virtual environment"
        echo "  help       - Show this help message"
        echo ""
        echo "Note: InvestorClaw automatically manages dependencies."
        echo "This script is optional for manual control."
        ;;
    *)
        log_error "Unknown command: $1"
        exit 1
        ;;
esac
